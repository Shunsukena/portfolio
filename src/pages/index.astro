---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import CategoryPills from '../components/CategoryPills.astro';
import AppsByCategory from '../components/AppsByCategory.astro';
import ContactCta from '../components/ContactCta.astro';
import SiteFooter from '../components/SiteFooter.astro';

const formUrl = 'https://forms.gle/YQCRc1M4JLJRrVVq9';
---

<Layout
  title="yanachan apps | 薬剤師・薬局・薬学生向けの便利アプリ＆国試対策ツール"
  description="薬剤師・薬局の業務効率化（一包化監査、棚編集など）や、薬学生の国家試験対策（薬理・薬剤の暗記）に役立つアプリを開発・公開しています。"
>
  <div class="app-shell relative mx-auto w-full">
    <main>
      <div class="app-region-top">
        <SiteHeader />
        <Hero
          brand="yanachan apps"
          tagline="薬剤師・薬局の業務効率化ツール（一包化監査、棚編集など）や、薬学生の国家試験対策（暗記）アプリを個人開発しています。現場や勉強のスキマ時間でサクッと使えるアプリをお試しください！"
        />
        <div class="pb-4">
          <CategoryPills />
        </div>
      </div>
      <div class="app-region-bottom">
        <AppsByCategory />
        <ContactCta formUrl={formUrl} />
      </div>
    </main>
    <SiteFooter />
  </div>
</Layout>
