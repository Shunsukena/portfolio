---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import AppCarousel from '../components/AppCarousel.astro';
import CategoryPills from '../components/CategoryPills.astro';
import AppsByCategory from '../components/AppsByCategory.astro';
import ContactCta from '../components/ContactCta.astro';
import SiteFooter from '../components/SiteFooter.astro';

const formUrl = 'https://forms.gle/YQCRc1M4JLJRrVVq9';
---

<Layout
  title="yanachan apps | 薬剤師・薬局・薬学生向けの便利アプリ＆国試対策ツール"
  description="薬剤師・薬局の業務効率化（一包化監査、棚編集など）や、薬学生の国家試験対策（薬理・薬剤の暗記）に役立つアプリを開発・公開しています。"
>
  <SiteHeader />

  <!-- 1. Hero: full-width title + description -->
  <Hero
    brand="yanachan apps"
    tagline={"薬剤師・薬局の業務効率化ツール（一包化監査、棚編集など）や、薬学生の国家試験対策（暗記）アプリを個人開発しています。\n現場や勉強のスキマ時間でサクッと使えるアプリをお試しください！"}
  />

  <!-- 2. App Carousel: full-width sliding showcase -->
  <AppCarousel />

  <!-- 3. Buttons + Category pills -->
  <div class="mx-auto w-full max-w-5xl px-5 sm:px-8">
    <div class="py-10 flex flex-col items-start gap-8 sm:flex-row sm:items-center sm:justify-between">
      <a
        href="#apps"
        class="inline-flex items-center justify-center rounded-full bg-slate-900 px-8 py-3.5 text-sm font-medium tracking-wide text-white transition hover:bg-slate-700"
      >
        アプリを見る
      </a>
      <CategoryPills />
    </div>
  </div>

  <!-- 4. App list by category -->
  <main class="mx-auto w-full max-w-5xl px-5 sm:px-8">
    <AppsByCategory />
  </main>

  <ContactCta formUrl={formUrl} />
  <SiteFooter />
</Layout>

<script>
  // Intersection Observer for fade-up animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
</script>
