---
import { categories } from '../data/projects';

const pills = categories.map((c) => ({
  href: `#cat-${c.id}`,
  label: c.label,
  emoji: c.emoji,
}));
---

<nav
  class="mx-auto flex w-full flex-wrap items-center justify-start gap-3 sm:justify-center"
  aria-label="カテゴリへジャンプ"
>
  {
    pills.map((c) => (
      <a
        href={c.href}
        class="inline-flex shrink-0 items-center gap-2 rounded-full border border-slate-200 bg-white px-5 py-2 text-sm font-medium text-slate-600 transition hover:border-slate-400 hover:text-slate-900"
      >
        <span aria-hidden="true" class="select-none text-base leading-none">
          {c.emoji}
        </span>
        {c.label}
      </a>
    ))
  }
</nav>
