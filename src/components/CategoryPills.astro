---
import { categories } from '../data/projects';

const pills = categories.map((c) => ({
  href: `#cat-${c.id}`,
  label: c.label,
  emoji: c.emoji,
}));
---

<nav
  class="mx-auto flex w-full max-w-md flex-col gap-2 px-4 pb-1 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden sm:flex-row sm:flex-nowrap sm:items-center sm:gap-2 sm:overflow-x-auto sm:overscroll-x-contain"
  aria-label="カテゴリへジャンプ"
>
  {
    pills.map((c) => (
      <a
        href={c.href}
        class="inline-flex w-full shrink-0 items-center justify-center gap-1.5 rounded-full border border-slate-200 bg-white/90 px-3.5 py-1.5 text-sm text-slate-700 shadow-sm transition hover:border-cyan-200 hover:bg-cyan-50/80 hover:text-cyan-800 sm:w-auto sm:justify-start"
      >
        <span aria-hidden="true" class="select-none text-base leading-none">
          {c.emoji}
        </span>
        {c.label}
      </a>
    ))
  }
</nav>
