---
import { apps } from '../data/projects';

// All apps for the carousel
const carouselApps = apps.filter((a) => a.image);
---

<section class="relative w-full overflow-hidden border-y border-slate-100 bg-slate-50" aria-label="アプリ紹介スライダー">
  <!-- Gradient edges for fade effect -->
  <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 sm:w-24 bg-gradient-to-r from-slate-50 to-transparent"></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 sm:w-24 bg-gradient-to-l from-slate-50 to-transparent"></div>

  <div class="carousel-track flex gap-0" aria-live="off">
    {/* Render items twice for seamless loop */}
    {[...carouselApps, ...carouselApps].map((app) => (
      <a
        href={app.href || '#apps'}
        class="carousel-item flex shrink-0 items-center gap-5 sm:gap-6 px-8 sm:px-10 py-8 sm:py-10 transition-opacity hover:opacity-70"
        target={app.href?.startsWith('http') ? '_blank' : undefined}
        rel={app.href?.startsWith('http') ? 'noreferrer' : undefined}
      >
        <img
          src={app.image}
          alt={app.imageAlt ?? ''}
          class="h-20 w-20 shrink-0 rounded-2xl object-contain shadow-sm sm:h-24 sm:w-24"
          loading="lazy"
          decoding="async"
        />
        <div class="flex min-w-0 flex-col gap-1">
          <span class="font-display text-base font-semibold tracking-tight text-slate-800 sm:text-lg whitespace-nowrap">
            {app.title}
          </span>
          <span class="text-sm leading-relaxed text-slate-500 whitespace-nowrap">
            {app.description.split('\n')[0]}
          </span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .carousel-track {
    animation: scroll-carousel 40s linear infinite;
    width: max-content;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll-carousel {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Reduce motion for accessibility */
  @media (prefers-reduced-motion: reduce) {
    .carousel-track {
      animation: none;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
  }
</style>
