---
import { apps } from '../data/projects';

const carouselApps = apps.filter((a) => a.image);
---

<section class="relative w-full overflow-hidden border-y border-slate-100 bg-slate-50" aria-label="アプリ紹介スライダー">
  <!-- Gradient edges -->
  <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 sm:w-24 bg-gradient-to-r from-slate-50 to-transparent"></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 sm:w-24 bg-gradient-to-l from-slate-50 to-transparent"></div>

  <div id="carousel-track" class="flex gap-0 cursor-grab active:cursor-grabbing select-none" style="width: max-content;" aria-live="off">
    {[...carouselApps, ...carouselApps, ...carouselApps].map((app) => (
      <a
        href={app.href || '#apps'}
        class="carousel-item flex shrink-0 items-center gap-5 sm:gap-6 px-8 sm:px-10 py-8 sm:py-10 transition-opacity hover:opacity-70"
        target={app.href?.startsWith('http') ? '_blank' : undefined}
        rel={app.href?.startsWith('http') ? 'noreferrer' : undefined}
        draggable="false"
      >
        <img
          src={app.image}
          alt={app.imageAlt ?? ''}
          class="h-20 w-20 shrink-0 rounded-2xl object-contain shadow-sm sm:h-24 sm:w-24 pointer-events-none"
          loading="lazy"
          decoding="async"
        />
        <div class="flex min-w-0 flex-col gap-1 pointer-events-none">
          <span class="font-display text-base font-semibold tracking-tight text-slate-800 sm:text-lg whitespace-nowrap">
            {app.title}
          </span>
          <span class="text-sm leading-relaxed text-slate-500 whitespace-nowrap">
            {app.description.split('\n')[0]}
          </span>
        </div>
      </a>
    ))}
  </div>
</section>

<script>
  const track = document.getElementById('carousel-track')!;
  const SPEED = 0.6; // px per frame
  const RESUME_DELAY = 2500; // ms after user releases

  let pos = 0;
  let isDown = false;
  let startX = 0;
  let dragStartPos = 0;
  let dragDistance = 0;
  let resumeTimer: ReturnType<typeof setTimeout> | null = null;
  let paused = false;
  let rafId: number;

  // Calculate the width of one "set" of items (1/3 of total since we tripled)
  function getOneSetWidth() {
    return track.scrollWidth / 3;
  }

  // Seamless loop: wrap position
  function wrapPos() {
    const oneSet = getOneSetWidth();
    if (pos <= -oneSet * 2) pos += oneSet;
    if (pos >= 0) pos -= oneSet;
  }

  // Animation loop
  function tick() {
    if (!paused && !isDown) {
      pos -= SPEED;
    }
    wrapPos();
    track.style.transform = `translateX(${pos}px)`;
    rafId = requestAnimationFrame(tick);
  }

  // Start auto-scroll from one-set offset
  pos = -getOneSetWidth();
  rafId = requestAnimationFrame(tick);

  // --- Mouse drag ---
  track.addEventListener('mousedown', (e) => {
    isDown = true;
    startX = e.clientX;
    dragStartPos = pos;
    dragDistance = 0;
    if (resumeTimer) clearTimeout(resumeTimer);
    paused = true;
  });

  window.addEventListener('mousemove', (e) => {
    if (!isDown) return;
    const dx = e.clientX - startX;
    dragDistance = Math.abs(dx);
    pos = dragStartPos + dx;
  });

  window.addEventListener('mouseup', () => {
    if (!isDown) return;
    isDown = false;
    resumeTimer = setTimeout(() => { paused = false; }, RESUME_DELAY);
  });

  // Prevent click navigation if the user dragged
  track.addEventListener('click', (e) => {
    if (dragDistance > 5) {
      e.preventDefault();
      e.stopPropagation();
    }
  }, true);

  // --- Touch swipe ---
  let touchStartX = 0;
  let touchDragDistance = 0;

  track.addEventListener('touchstart', (e) => {
    isDown = true;
    touchStartX = e.touches[0].clientX;
    dragStartPos = pos;
    touchDragDistance = 0;
    if (resumeTimer) clearTimeout(resumeTimer);
    paused = true;
  }, { passive: true });

  track.addEventListener('touchmove', (e) => {
    if (!isDown) return;
    const dx = e.touches[0].clientX - touchStartX;
    touchDragDistance = Math.abs(dx);
    pos = dragStartPos + dx;
  }, { passive: true });

  track.addEventListener('touchend', () => {
    isDown = false;
    resumeTimer = setTimeout(() => { paused = false; }, RESUME_DELAY);
    // Prevent click if swiped
    if (touchDragDistance > 10) {
      const handler = (e: Event) => { e.preventDefault(); e.stopPropagation(); };
      track.addEventListener('click', handler, { capture: true, once: true });
    }
  });

  // Pause on hover (desktop)
  track.addEventListener('mouseenter', () => {
    if (!isDown) { paused = true; if (resumeTimer) clearTimeout(resumeTimer); }
  });
  track.addEventListener('mouseleave', () => {
    if (!isDown) { resumeTimer = setTimeout(() => { paused = false; }, 300); }
  });

  // Handle reduced motion preference
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    cancelAnimationFrame(rafId);
    track.style.overflowX = 'auto';
    track.style.transform = 'none';
  }
</script>
