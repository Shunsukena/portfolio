---
interface Props {
  brand: string;
  tagline: string;
}

const { brand, tagline } = Astro.props;
---

<section
  class="relative w-full pb-16 pt-24 sm:pt-32 lg:pt-40 px-5 sm:px-8"
  aria-labelledby="hero-heading"
>
  <div class="mx-auto max-w-5xl">
    <p
      class="mb-8 inline-flex items-center gap-2 rounded-full border border-slate-200 px-4 py-1.5 text-xs font-medium tracking-wide text-slate-500"
    >
      <span
        class="h-1.5 w-1.5 rounded-full bg-emerald-400"
      />
      indie apps · モバイル＆Web
    </p>
  </div>
  <div class="mx-auto max-w-5xl lg:max-w-none lg:px-[8vw]">
    <h1
      id="hero-heading"
      class="font-display text-4xl font-light leading-[1.2] tracking-tight text-slate-900 sm:text-5xl lg:text-7xl lg:leading-[1.1]"
    >
      {brand}
    </h1>
    <p
      class="mt-8 text-base font-normal leading-[2] text-slate-500 sm:text-lg sm:leading-[2] lg:text-xl lg:leading-[2] max-w-3xl"
    >
      {tagline}
    </p>
  </div>
</section>
