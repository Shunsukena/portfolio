---
interface Props {
  brand: string;
  tagline: string;
}

const { brand, tagline } = Astro.props;
---

<section
  class="relative mx-auto w-full max-w-md px-4 pb-6 pt-12 sm:pt-16"
  aria-labelledby="hero-heading"
>
  <p
    class="mb-3 inline-flex items-center gap-2 rounded-full border border-slate-200/80 bg-white/80 px-3 py-1 text-xs font-medium text-slate-600 shadow-sm backdrop-blur"
  >
    <span
      class="h-1.5 w-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px] shadow-emerald-500/50"
    />
    indie apps · モバイル＆Web
  </p>
  <h1
    id="hero-heading"
    class="font-display text-4xl font-semibold leading-tight tracking-tight text-slate-900 sm:text-5xl sm:leading-tight"
  >
    {brand}
  </h1>
  <p
    class="mt-4 max-w-2xl text-pretty text-base leading-relaxed text-slate-600 sm:text-lg"
  >
    {tagline}
  </p>
  <div class="mt-8 flex flex-wrap items-center gap-3">
    <a
      href="#apps"
      class="inline-flex items-center justify-center rounded-xl bg-cyan-600 px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-cyan-600/20 transition hover:bg-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-500"
    >
      アプリを見る
    </a>
    <a
      href="https://x.com/Yanachan3pharma"
      class="inline-flex items-center justify-center gap-2 rounded-xl border border-slate-800/10 bg-slate-900 px-5 py-2.5 text-sm font-medium text-white shadow-sm transition hover:bg-slate-800"
      rel="me noreferrer"
      target="_blank"
      aria-label="X（@Yanachan3pharma）をフォロー"
    >
      <svg
        class="h-4 w-4 shrink-0"
        viewBox="0 0 24 24"
        aria-hidden="true"
        fill="currentColor"
      >
        <path
          d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
        />
      </svg>
      フォロー
    </a>
    <a
      href="#contact"
      class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-5 py-2.5 text-sm font-medium text-slate-800 shadow-sm transition hover:border-slate-300 hover:bg-slate-50"
    >
      お問い合わせ
    </a>
  </div>
</section>
