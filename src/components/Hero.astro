---
interface Props {
  brand: string;
  tagline: string;
}

const { brand, tagline } = Astro.props;
---

<section
  class="relative mx-auto w-full pb-16 pt-24 sm:pt-32 lg:pt-40"
  aria-labelledby="hero-heading"
>
  <p
    class="mb-8 inline-flex items-center gap-2 rounded-full border border-slate-200 px-4 py-1.5 text-xs font-medium tracking-wide text-slate-500"
  >
    <span
      class="h-1.5 w-1.5 rounded-full bg-emerald-400"
    />
    indie apps · モバイル＆Web
  </p>
  <h1
    id="hero-heading"
    class="font-display text-4xl font-light leading-[1.2] tracking-tight text-slate-900 sm:text-5xl lg:text-6xl lg:leading-[1.15]"
  >
    {brand}
  </h1>
  <p
    class="mt-8 max-w-xl text-base font-normal leading-[2] text-slate-500 sm:text-lg sm:leading-[2]"
  >
    {tagline}
  </p>
  <div class="mt-12 flex flex-wrap items-center gap-4">
    <a
      href="#apps"
      class="inline-flex items-center justify-center rounded-full bg-slate-900 px-8 py-3.5 text-sm font-medium tracking-wide text-white transition hover:bg-slate-700"
    >
      アプリを見る
    </a>
    <a
      href="https://x.com/Yanachan3pharma"
      class="inline-flex items-center justify-center gap-2 rounded-full border border-slate-200 px-8 py-3.5 text-sm font-medium tracking-wide text-slate-600 transition hover:border-slate-400 hover:text-slate-900"
      rel="me noreferrer"
      target="_blank"
      aria-label="X（@Yanachan3pharma）をフォロー"
    >
      <svg
        class="h-4 w-4 shrink-0"
        viewBox="0 0 24 24"
        aria-hidden="true"
        fill="currentColor"
      >
        <path
          d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
        />
      </svg>
      フォロー
    </a>
  </div>
</section>
