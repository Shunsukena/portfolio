---
import type { PortfolioApp } from '../data/projects';
import { statusLabel, statusStyle } from '../lib/status';

interface Props {
  app: PortfolioApp;
}

const { app } = Astro.props;

const isAppStore = Boolean(app.href?.includes('apps.apple.com'));
---

<article
  class="group relative flex h-full w-full max-w-full flex-col overflow-hidden rounded-2xl border border-slate-200/80 bg-surface-50/90 p-5 shadow-sm ring-1 ring-slate-100 transition hover:border-cyan-200/80 hover:shadow-md hover:shadow-cyan-500/10"
>
  {app.image && (
    <div class="mb-4 flex h-32 max-h-32 w-full min-w-0 items-start justify-center sm:justify-start">
      <img
        src={app.image}
        alt={app.imageAlt ?? ''}
        class="h-auto w-auto max-h-32 max-w-32 rounded-2xl object-contain object-top shadow-md ring-1 ring-slate-200/80 sm:max-h-32 sm:max-w-32"
        loading="lazy"
        decoding="async"
      />
    </div>
  )}
  <div class="flex items-start justify-between gap-3">
    <h3
      class="font-display text-lg font-semibold text-slate-900 group-hover:text-cyan-800"
    >
      {app.title}
    </h3>
    <div class="flex shrink-0 flex-wrap items-center justify-end gap-1.5">
      {app.tag && (
        <span class="rounded-md border border-fuchsia-200 bg-fuchsia-50 px-1.5 py-0.5 text-[0.7rem] font-medium text-fuchsia-800"
        >
          {app.tag}
        </span>
      )}
      <span
        class:list={[
          'whitespace-nowrap rounded-md border px-1.5 py-0.5 text-[0.7rem] font-medium',
          statusStyle(app.status),
        ]}
      >
        {statusLabel(app.status)}
      </span>
    </div>
  </div>
  <p
    class="mt-2 flex-1 text-pretty text-sm leading-relaxed text-slate-600 whitespace-pre-line"
  >
    {app.description}
  </p>
  {app.href && isAppStore ? (
    <a
      href={app.href}
      class="mt-4 inline-flex w-fit max-w-full items-stretch overflow-hidden rounded-[10px] bg-black pr-3 text-left text-white shadow-sm ring-1 ring-black/20 transition hover:bg-neutral-800 hover:ring-black/30 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2"
      rel="noreferrer"
      target="_blank"
      aria-label={`${app.title} — App Storeでダウンロード（新しいタブで開きます）`}
    >
      <span class="flex shrink-0 items-center border-r border-white/10 px-2.5 py-1.5 sm:px-3">
        <svg
          class="h-7 w-7 sm:h-8 sm:w-8"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
          />
        </svg>
      </span>
      <span class="flex min-w-0 flex-col items-start justify-center py-1.5 pl-2 pr-0.5 leading-none sm:py-2">
        <span
          class="text-[0.6rem] font-normal tracking-wide text-white/90 sm:text-[0.65rem]"
        >
          ダウンロード
        </span>
        <span
          class="mt-0.5 font-sans text-[0.9rem] font-semibold tracking-tight sm:text-[0.95rem]"
        >
          App Store
        </span>
      </span>
    </a>
  ) : app.href ? (
    <a
      href={app.href}
      class="mt-4 inline-flex items-center text-sm font-medium text-cyan-700 hover:text-cyan-800"
    >
      詳しく見る
      <span class="ml-1 transition group-hover:translate-x-0.5">→</span>
    </a>
  ) : (
    <p class="mt-4 text-xs text-slate-500">Store / Web は準備中</p>
  )}
</article>
