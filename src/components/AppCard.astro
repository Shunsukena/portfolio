---
import type { PortfolioApp } from '../data/projects';
import { statusLabel, statusStyle } from '../lib/status';

interface Props {
  app: PortfolioApp;
}

const { app } = Astro.props;

const isAppStore = Boolean(app.href?.includes('apps.apple.com'));
---

<article
  class="group flex h-full w-full flex-col overflow-hidden rounded-2xl border border-slate-100 bg-white transition-shadow duration-300 hover:shadow-lg hover:shadow-slate-200/60"
>
  {app.image && (
    <div class="flex items-center justify-center bg-slate-50 px-8 py-10">
      <img
        src={app.image}
        alt={app.imageAlt ?? ''}
        class="h-36 w-36 rounded-[1.75rem] object-contain shadow-sm sm:h-44 sm:w-44"
        loading="lazy"
        decoding="async"
      />
    </div>
  )}
  <div class="flex flex-1 flex-col p-6">
    <div class="flex items-start justify-between gap-3">
      <h3
        class="font-display text-lg font-semibold tracking-tight text-slate-800 group-hover:text-slate-600 transition-colors"
      >
        {app.title}
      </h3>
      <div class="flex shrink-0 flex-wrap items-center justify-end gap-1.5 mt-0.5">
        {app.tag && (
          <span class="rounded-full border border-fuchsia-200 bg-fuchsia-50 px-2 py-0.5 text-[0.65rem] font-medium text-fuchsia-700">
            {app.tag}
          </span>
        )}
        <span
          class:list={[
            'whitespace-nowrap rounded-full border px-2 py-0.5 text-[0.65rem] font-medium',
            statusStyle(app.status),
          ]}
        >
          {statusLabel(app.status)}
        </span>
      </div>
    </div>
    <p
      class="mt-3 flex-1 text-sm leading-[1.8] text-slate-500 whitespace-pre-line"
    >
      {app.description}
    </p>
    {app.href && isAppStore ? (
      <a
        href={app.href}
        class="mt-5 inline-flex w-fit items-stretch overflow-hidden rounded-xl bg-slate-900 pr-3 text-left text-white shadow-sm transition hover:bg-slate-700"
        rel="noreferrer"
        target="_blank"
        aria-label={`${app.title} — App Storeでダウンロード（新しいタブで開きます）`}
      >
        <span class="flex shrink-0 items-center border-r border-white/10 px-2.5 py-1.5">
          <svg
            class="h-6 w-6 sm:h-7 sm:w-7"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
            />
          </svg>
        </span>
        <span class="flex min-w-0 flex-col items-start justify-center py-1.5 pl-2.5 leading-none">
          <span class="text-[0.6rem] font-normal tracking-wide text-white/80">
            ダウンロード
          </span>
          <span class="mt-0.5 font-sans text-sm font-semibold tracking-tight">
            App Store
          </span>
        </span>
      </a>
    ) : app.href ? (
      <a
        href={app.href}
        class="mt-5 inline-flex items-center text-sm font-medium text-slate-500 transition hover:text-slate-800"
      >
        詳しく見る
        <span class="ml-1.5 transition-transform group-hover:translate-x-1">→</span>
      </a>
    ) : (
      <p class="mt-5 text-xs text-slate-400">Store / Web は準備中</p>
    )}
  </div>
</article>
