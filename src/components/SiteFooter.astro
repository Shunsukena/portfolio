---
const year = new Date().getFullYear();
const brand = 'yanachan apps';
---

<footer
  class="border-t border-slate-100 bg-white px-5 sm:px-8 py-12 text-center"
>
  <p class="text-xs tracking-wide text-slate-400">
    © {year} {brand}
  </p>
  <nav
    class="mt-4 flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-xs text-slate-400"
    aria-label="法的情報"
  >
    <a class="transition hover:text-slate-700" href="/terms">利用規約</a>
    <span class="text-slate-200" aria-hidden="true">|</span>
    <a class="transition hover:text-slate-700" href="/privacy">プライバシーポリシー</a>
  </nav>
</footer>
