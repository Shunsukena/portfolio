---
import { apps, categories, type AppCategory } from '../data/projects';
import AppCard from './AppCard.astro';

const byCategory = (id: AppCategory) => apps.filter((a) => a.category === id);
---

<section
  id="apps"
  class="mx-auto w-full scroll-mt-8 py-20"
  aria-labelledby="apps-heading"
>
  <h2
    id="apps-heading"
    class="font-display text-2xl font-light tracking-tight text-slate-900 sm:text-3xl"
  >
    アプリ
  </h2>
  <div class="mt-2 h-px w-12 bg-slate-300"></div>

  {
    categories.map((cat) => {
      const list = byCategory(cat.id);
      if (list.length === 0) {
        return null;
      }
      return (
        <div id={`cat-${cat.id}`} class="scroll-mt-20 mt-16 fade-up">
          <div class="mb-8 flex items-center gap-3">
            <span class="text-2xl" aria-hidden="true">
              {cat.emoji}
            </span>
            <h3 class="font-display text-xl font-normal tracking-wide text-slate-700">
              {cat.label}
            </h3>
          </div>
          <ul
            class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3 list-none [padding-inline:0]"
            aria-label={`${cat.label}の一覧`}
          >
            {list.map((app) => (
              <li>
                <AppCard app={app} />
              </li>
            ))}
          </ul>
        </div>
      );
    })
  }
</section>
