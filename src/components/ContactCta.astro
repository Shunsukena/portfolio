---
interface Props {
  formUrl: string;
}

const { formUrl } = Astro.props;
---

<section
  id="contact"
  class="scroll-mt-8 border-t border-slate-100 bg-slate-50 fade-up"
  aria-labelledby="contact-heading"
>
  <div class="mx-auto max-w-5xl px-5 sm:px-8 py-24 sm:py-32 text-center">
    <h2
      id="contact-heading"
      class="font-display text-2xl font-light tracking-tight text-slate-900 sm:text-3xl"
    >
      お問い合わせ
    </h2>
    <div class="mx-auto mt-2 h-px w-12 bg-slate-300"></div>
    <p class="mt-6 text-base text-slate-500 max-w-lg mx-auto leading-[1.8]">
      コラボ・取材・不具合報告のほか、リクエストもお気軽にどうぞ。<br class="hidden sm:block" />追ってご返信します。
    </p>
    <a
      href={formUrl}
      class="mt-10 inline-flex items-center justify-center rounded-full bg-slate-900 px-10 py-4 text-sm font-medium tracking-wide text-white transition hover:bg-slate-700"
      rel={formUrl.startsWith('mailto:') ? undefined : 'noreferrer'}
      target={formUrl.startsWith('mailto:') ? undefined : '_blank'}
    >
      {formUrl.startsWith('mailto:') ? 'メールを送る' : 'Googleフォームを開く'}
    </a>
  </div>
</section>
