---
interface Props {
  formUrl: string;
}

const { formUrl } = Astro.props;
---

<section
  id="contact"
  class="mx-auto w-full max-w-md scroll-mt-8 px-4 pb-16 pt-4"
  aria-labelledby="contact-heading"
>
  <div
    class="overflow-hidden rounded-3xl border border-cyan-200/60 bg-gradient-to-br from-cyan-50/90 via-surface-50/90 to-fuchsia-50/80 p-6 shadow-sm"
  >
    <h2
      id="contact-heading"
      class="font-display text-2xl font-semibold text-slate-900 sm:text-3xl"
    >
      お問い合わせはフォームにて承ります。
    </h2>
    <p class="mt-3 max-w-2xl text-pretty text-slate-600">
      コラボ・取材・不具合報告のほか、リクエストもお気軽にどうぞ。追ってご返信します。
    </p>
    <a
      href={formUrl}
      class="mt-6 inline-flex items-center justify-center rounded-xl bg-cyan-600 px-6 py-3 text-sm font-semibold text-white shadow-md shadow-cyan-600/20 transition hover:bg-cyan-500"
      rel={formUrl.startsWith('mailto:') ? undefined : 'noreferrer'}
      target={formUrl.startsWith('mailto:') ? undefined : '_blank'}
    >
      {formUrl.startsWith('mailto:') ? 'メールを送る' : 'Googleフォームを開く'}
    </a>
  </div>
</section>
