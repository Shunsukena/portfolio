---
const brand = 'yanachan apps';
---

<header
  class="sticky top-0 z-20 border-b border-slate-100 bg-white/95 backdrop-blur-sm"
>
  <div
    class="mx-auto flex h-16 w-full max-w-5xl items-center justify-between px-5 sm:px-8"
  >
    <a
      href="#"
      class="font-display text-base font-semibold tracking-wide text-slate-800 transition hover:text-slate-500"
    >
      {brand}
    </a>
    <nav
      class="flex items-center gap-8 text-[0.8rem] font-medium tracking-widest uppercase text-slate-400"
      aria-label="主要ナビ"
    >
      <a class="transition hover:text-slate-800" href="#apps">Apps</a>
      <a class="transition hover:text-slate-800" href="#contact">Contact</a>
    </nav>
  </div>
</header>
