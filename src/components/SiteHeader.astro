---
const brand = 'yanachan apps';
---

<header
  class="sticky top-0 z-20 border-b border-cyan-200/30 bg-white/30 backdrop-blur-xl"
>
  <div
    class="mx-auto flex h-14 w-full max-w-7xl items-center justify-between px-4 lg:px-8"
  >
    <a
      href="#"
      class="font-display text-sm font-semibold tracking-tight text-slate-900 transition hover:text-cyan-700"
    >
      {brand}
    </a>
    <nav
      class="flex items-center gap-4 text-sm text-slate-600"
      aria-label="主要ナビ"
    >
      <a class="hover:text-slate-900" href="#apps">アプリ</a>
      <a class="hover:text-slate-900" href="#contact">連絡</a>
    </nav>
  </div>
</header>
